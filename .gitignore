# ---- AID / Claude tooling (not part of the runtime) ----
.aid/
.claude/
.mcp.json
CLAUDE.md

# ---- Dev-only artifacts (not served by the app) ----
# docs/ IS tracked — PRD, tech-spec, runbook, code reviews, evaluation
# reports + QA screenshots. Excluded from Firebase Hosting via
# firebase.json `ignore`. Large binaries (video recordings) stay out
# via the patterns below — keep markdown + PNGs.
docs/**/*.mp4
docs/**/*.mov
docs/**/*.zip
test-route-filter.html
download-polygons.js
# tests/ IS tracked — offline suite (filter, shareLink, tbt-step-index) +
# Playwright E2E (tests/e2e/) are the quality gate for the repo. The
# generated output below is not.
tests/e2e/playwright-report/
tests/e2e/.last-run.json
test-results/
playwright-report/

# ---- Secrets ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- Node (future-proof; no package.json yet) ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- OS junk ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ---- Editors / IDEs ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ---- Logs / tmp ----
*.log
*.tmp
*.bak
.cache/

# ---- Firebase CLI runtime artifacts (config files ARE tracked) ----
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# ---- Build output (future-proof) ----
dist/
build/
out/
coverage/
