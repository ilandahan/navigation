{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22",
      "region": "me-west1",
      "ignore": ["node_modules", ".git", "*.log", ".env*"]
    }
  ],
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".mcp.json",
      ".gitignore",
      "CLAUDE.md",
      "firestore.rules",
      "firestore.indexes.json",
      "download-polygons.js",
      "test-route-filter.html",
      ".firebase/**",
      ".git/**",
      ".aid/**",
      ".claude/**",
      "docs/**",
      "tests/**",
      "node_modules/**",
      "functions/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": { "functionId": "api", "region": "me-west1" }
      }
    ]
  }
}
